APP_NAME=EduGraph AI
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-in-production

# PostgreSQL – run: createdb edugraph
DATABASE_URL=postgresql+asyncpg://edugraph:edugraph@localhost:5432/edugraph

# Neo4j – default community edition (optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=edugraph

# ChromaDB – local persistent path
CHROMA_PATH=./data/chroma

# Ollama – local LLM server (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# CORS
CORS_ORIGINS=["http://localhost:3000"]
